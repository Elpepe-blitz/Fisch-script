local Players           = game:GetService("Players")
local Workspace         = game:GetService("Workspace")
local RunService        = game:GetService("RunService")

local LocalPlayer       = Players.LocalPlayer
local Camera            = Workspace.CurrentCamera

-- ==================== CONFIGURACIÓN ====================
local CONFIG = {
    Enabled          = true,          -- Activar/desactivar el aimbot
    RoleSheriff      = "Sheriff",
    RoleMurderer     = "Murderer",

    -- Humanized delay (anti-detection)
    DelayMin         = 80,            -- milisegundos
    DelayMax         = 140,

    -- Prioridad (solo para Murderer)
    PrioritySheriff  = 100,
    PriorityInnocent = 50,
}

-- ==================== UTILIDADES ====================
local function getMyRole()
    local roleObj = LocalPlayer:FindFirstChild("Role")
    return roleObj and roleObj.Value or nil
end

local function humanDelay()
    -- Usamos task.wait para mayor precisión y compatibilidad con executors modernos
    local delay = CONFIG.DelayMin + math.random() * (CONFIG.DelayMax - CONFIG.DelayMin)
    task.wait(delay / 1000) -- convertimos ms a segundos
end

-- ==================== BÚSQUEDA DE OBJETIVO ====================
local function findTarget()
    local myRole = getMyRole()
    if not myRole then return nil end

    local bestTarget      = nil
    local bestPriority    = -1
    local bestDistance    = math.huge

    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        local character = player.Character
        if not character or not character:FindFirstChild("HumanoidRootPart") then continue end

        local roleObj = player:FindFirstChild("Role")
        if not roleObj then continue end

        local targetRole = roleObj.Value
        local isValidTarget = false
        local priority      = 0

        -- Lógica según tu rol actual
        if myRole == CONFIG.RoleSheriff and targetRole == CONFIG.RoleMurderer then
            isValidTarget = true
            priority      = CONFIG.PrioritySheriff
        elseif myRole == CONFIG.RoleMurderer and targetRole \~= CONFIG.RoleMurderer then
            isValidTarget = true
            priority      = (targetRole == CONFIG.RoleSheriff) and CONFIG.PrioritySheriff or CONFIG.PriorityInnocent
        end

        if not isValidTarget then continue end

        local distance = (character.HumanoidRootPart.Position - myRoot.Position).Magnitude

        -- Comparación por prioridad primero, luego por distancia
        local betterPriority = priority > bestPriority
        local samePriorityButCloser = (priority == bestPriority and distance < bestDistance)

        if betterPriority or samePriorityButCloser then
            bestPriority = priority
            bestDistance = distance
            bestTarget   = character.HumanoidRootPart
        end
    end

    return bestTarget
end

-- ==================== SILENT AIMBOT CORE ====================
local function onRenderStepped()
    if not CONFIG.Enabled then return end

    local myCharacter = LocalPlayer.Character
    if not myCharacter or not myCharacter:FindFirstChild("HumanoidRootPart") then return end

    local targetRoot = findTarget()
    if not targetRoot then return end

    -- Buscar el arma actual
    local tool = myCharacter:FindFirstChildOfClass("Tool")
    if not tool then return end

    local handle = tool:FindFirstChild("Handle")
    local remote = tool:FindFirstChild("Remote") -- Nombre común en MM2
    if not handle or not remote then return end

    -- Silent aim: calculamos dirección exacta hacia el objetivo
    local origin    = Camera.CFrame.Position
    local direction = (targetRoot.Position - origin).Unit * 1000

    -- Anti-detection: delay humanizado antes de disparar
    humanDelay()

    -- FireServer seguro con pcall
    pcall(function()
        remote:FireServer(direction)
    end)
end

-- ==================== CONEXIÓN PRINCIPAL ====================
RunService.RenderStepped:Connect(onRenderStepped)

