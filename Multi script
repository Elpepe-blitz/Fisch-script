-- --- LÓGICA DE ROLES Y COMBATE ---
local function getTarget()
    local myRole = "Innocent"
    if Player.Backpack:FindFirstChild("Knife") or (Player.Character and Player.Character:FindFirstChild("Knife")) then myRole = "Murderer" end
    if Player.Backpack:FindFirstChild("Gun") or (Player.Character and Player.Character:FindFirstChild("Gun")) then myRole = "Sheriff" end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            -- Si soy Sheriff, busco al que tenga el cuchillo
            if myRole == "Sheriff" then
                if p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife") then
                    return p.Character.HumanoidRootPart
                end
            -- Si soy Murderer, busco al que tenga la pistola
            elseif myRole == "Murderer" then
                if p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun") then
                    return p.Character.HumanoidRootPart
                end
            end
        end
    end
    return nil
end

-- Ejecución en bucle
RunService.RenderStepped:Connect(function()
    local char = Player.Character
    if not char then return end

    -- Mantener Invisibilidad
    if invActive then
        for _, v in pairs(char:GetDescendants()) do
            if (v:IsA("BasePart") or v:IsA("Decal")) and v.Name ~= "HumanoidRootPart" then
                v.Transparency = 1
            end
        end
    end

    -- Lógica Silent Aim (Redirección de cámara suave)
    if aimActive then
        local targetPart = getTarget()
        if targetPart then
            local cam = workspace.CurrentCamera
            cam.CFrame = CFrame.new(cam.CFrame.Position, targetPart.Position)
        end
    end
end)

print("Hub de MM2 cargado. ¡Buena suerte!")
