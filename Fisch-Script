-- ==================== LÓGICA DEL AUTO FARM ====================
local function SimulateCast()
    -- Simula lanzar la caña (mantén y suelta clic)
    VirtualInputManager:SendMouseButtonEvent(500, 500, 0, true, game, 0) -- left click down
    wait(1.2) -- potencia de lanzamiento
    VirtualInputManager:SendMouseButtonEvent(500, 500, 0, false, game, 0) -- release
end

local function SimulateShakeReel()
    -- Simula sacudidas y recogida cuando muerde el pez
    for i = 1, 8 do
        VirtualInputManager:SendMouseButtonEvent(500, 500, 0, true, game, 0)
        wait(0.08)
        VirtualInputManager:SendMouseButtonEvent(500, 500, 0, false, game, 0)
        wait(0.15)
    end
end

RunService.Heartbeat:Connect(function()
    if not autoFarmEnabled then return end
    
    -- Auto Cast + Shake + Reel (loop básico pero efectivo)
    if character:FindFirstChild("FishingRod") or player.Backpack:FindFirstChild("FishingRod") then
        SimulateCast()
        wait(3) -- espera a que muerda
        SimulateShakeReel()
        wait(2)
    end
end)

